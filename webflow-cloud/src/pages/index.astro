---
// The whole page IS the form, wrapped in the site layout (navbar + footer) so
// visitors can navigate the rest of the site. Prerendered static shell; the form
// itself is a client-only React island (it relies on window/fetch/timers).
export const prerender = true;
import SiteLayout from "../layouts/SiteLayout.astro";
import LeadIntakeForm from "../components/LeadIntakeForm.jsx";
---

<SiteLayout>
  <LeadIntakeForm client:only="react" />
</SiteLayout>
